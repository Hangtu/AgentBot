# ==============================================================================
# NextLaunch — PRODUCTION Environment Variables Template
# ==============================================================================
# Copy this file to .env.prod and fill in your PRODUCTION values:
#   cp .env.prod.example .env.prod
#
# DO NOT COMMIT .env.prod to version control!
# Use this file specifically to run production DB scripts from your local machine.
# e.g., npm run db:push:prod
# ==============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ APP                                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_APP_URL=https://your-production-domain.com

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DATABASE — NeonDB (Serverless Postgres) - PRODUCTION                        │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
DATABASE_URL="postgresql://user:password@ep-prod-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AUTH — Clerk - PRODUCTION                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk_publishable_key_here
CLERK_SECRET_KEY=clerk_secret_key_here

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PAYMENTS — Stripe - PRODUCTION                                              │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=publishable_key_here
STRIPE_SECRET_KEY=secret_key_here
STRIPE_WEBHOOK_SECRET=webhook_secret_here

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ EMAIL — Resend - PRODUCTION                                                 │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@your-production-domain.com

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ STORAGE — Cloudflare R2 - PRODUCTION                                        │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=my-project-uploads-prod
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ ERROR MONITORING — Sentry - PRODUCTION                                      │
# └─────────────────────────────────────────────────────────────────────────────┘
# [OPTIONAL]
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
