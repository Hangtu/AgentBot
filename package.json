{
  "name": "agentbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf .next",
    "db:push": "drizzle-kit push",
    "db:push:prod": "dotenv -e .env.prod -- drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "dotenv -e .env.prod -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:studio:prod": "dotenv -e .env.prod -- drizzle-kit studio",
    "db:seed": "npx tsx src/lib/db/seed.ts",
    "db:seed:prod": "dotenv -e .env.prod -- npx tsx src/lib/db/seed.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.738.0",
    "@clerk/nextjs": "^6.12.12",
    "@google/genai": "^2.1.0",
    "@hookform/resolvers": "^5.0.1",
    "@neondatabase/serverless": "^1.0.0",
    "@sentry/nextjs": "^10.51.0",
    "@stripe/stripe-js": "^7.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.40.1",
    "lucide-react": "^0.483.0",
    "next": "16.1.6",
    "next-intl": "^4.1.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.55.0",
    "resend": "^4.5.2",
    "server-only": "^0.0.1",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.3",
    "stripe": "^18.1.0",
    "svix": "^1.85.0",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.9",
    "zod": "^3.24.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "!(.agents/**)*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "!(.agents/**)*.{json,md,yml,yaml}": "prettier --write"
  }
}
