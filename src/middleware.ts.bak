import { clerkMiddleware, createRouteMatcher } from "@clerk/nextjs/server";
import createIntlMiddleware from "next-intl/middleware";
import { NextResponse } from "next/server";
import type { NextRequest } from "next/server";
import { routing } from "@/i18n/routing";

// Routes that require authentication (with locale prefix support)
const isProtectedRoute = createRouteMatcher([
  "/(en|es)/dashboard(.*)",
  "/dashboard(.*)", // fallback without prefix
]);

// Admin API routes that require authentication
const isProtectedApiRoute = createRouteMatcher([
  "/api/v1/admin(.*)",
]);

const intlMiddleware = createIntlMiddleware(routing);

export default clerkMiddleware(async (auth, req: NextRequest) => {
  // Protect admin API routes — must be authenticated
  if (isProtectedApiRoute(req)) {
    const { userId } = await auth();
    if (!userId) {
      return NextResponse.json({ error: "Unauthorized" }, { status: 401 });
    }
  }

  // Protect dashboard pages — Clerk redirects to sign-in if not authenticated
  if (isProtectedRoute(req)) {
    await auth.protect();
  }

  // Apply next-intl middleware for locale routing
  return intlMiddleware(req);
});

export const config = {
  matcher: [
    // Skip Next.js internals and static files
    "/((?!_next|[^?]*\\.(?:html?|css|js(?!on)|jpe?g|webp|png|gif|svg|ttf|woff2?|ico|csv|docx?|xlsx?|zip|webmanifest)).*)",
    // Always run for API routes
    "/(api|trpc)(.*)",
  ],
};

