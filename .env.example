# ==============================================================================
# NextLaunch — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] can be left empty — the feature will be disabled.
# Variables with defaults will use the shown value if not overridden.
# ==============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ APP                                                                         │
# └─────────────────────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DATABASE — NeonDB (Serverless Postgres)                                     │
# │ Get your connection string at: https://console.neon.tech                    │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AUTH — Clerk                                                                │
# │ Get your keys at: https://dashboard.clerk.com → API Keys                   │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=clerk_publishable_key_here
CLERK_SECRET_KEY=clerk_secret_key_here

# Auth routes (defaults — only change if you customize your auth pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ PAYMENTS — Stripe                                                           │
# │ Get your keys at: https://dashboard.stripe.com/apikeys                     │
# │ Webhook secret: https://dashboard.stripe.com/webhooks                      │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=publishable_key_here
STRIPE_SECRET_KEY=secret_key_here
STRIPE_WEBHOOK_SECRET=webhook_secret_here

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ EMAIL — Resend                                                              │
# │ Get your API key at: https://resend.com/api-keys                           │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ STORAGE — Cloudflare R2 (S3-compatible)                                     │
# │ Get your credentials at: https://dash.cloudflare.com → R2 → Manage API    │
# └─────────────────────────────────────────────────────────────────────────────┘
# [REQUIRED]
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=my-project-uploads
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ ERROR MONITORING — Sentry                                                   │
# │ Get your DSN at: https://sentry.io → Project Settings → Client Keys        │
# │ Auth token: https://sentry.io → Settings → Auth Tokens                     │
# └─────────────────────────────────────────────────────────────────────────────┘
# [OPTIONAL] — leave empty to disable Sentry. App runs fine without it.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ BUILD                                                                       │
# └─────────────────────────────────────────────────────────────────────────────┘
# Set to "true" in CI/CD or Vercel if env vars are not available during build.
# This skips Zod validation so the build doesn't fail on missing keys.
SKIP_ENV_VALIDATION=