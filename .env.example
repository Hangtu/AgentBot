# ==============================================================================
# AgentBot — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ==============================================================================

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ APP & DATABASE                                                              │
# └─────────────────────────────────────────────────────────────────────────────┘
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NeonDB / Serverless Postgres Connection String (REQUIRED)
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AGENT BOT — LLM Providers                                                   │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ Set API keys for the LLM providers you want to use.                         │
# │ At minimum, set GEMINI_API_KEY or GROQ_API_KEY.                            │
# └─────────────────────────────────────────────────────────────────────────────┘
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AGENT BOT — Chatwoot Integration                                             │
# └─────────────────────────────────────────────────────────────────────────────┘
# Your Chatwoot API Token (profile settings -> access token)
CHATWOOT_API_TOKEN=

# Your Chatwoot Account ID
CHATWOOT_ACCOUNT_ID=

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AGENT BOT — Webhooks & Local Testing                                        │
# └─────────────────────────────────────────────────────────────────────────────┘
# Local bot API key (for local simulation/testing of webhooks)
LOCAL_BOT_API_KEY=ak_live_local

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ BUILD                                                                       │
# └─────────────────────────────────────────────────────────────────────────────┘
# Set to "true" to skip Zod environment variable validation if needed.
SKIP_ENV_VALIDATION=